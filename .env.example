# Google OAuth 2.0
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Google Service Account (for Sheets API)
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# Admin Google Sheet (contains "users" tab for whitelist)
ADMIN_SHEET_ID=your-admin-sheet-id

# iCloud CalDAV
ICLOUD_APPLE_ID=your-apple-id@icloud.com
ICLOUD_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
ICLOUD_CALENDAR_NAME=貓咪照護

# Token encryption (any random string, used to encrypt OAuth tokens in cookies)
TOKEN_ENCRYPTION_KEY=your-random-secret-key-here
